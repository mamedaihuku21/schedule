<%
  chart_uid = "chart-#{SecureRandom.hex(4)}"
  events = (local_assigns[:chart_events] || []).sort_by(&:start_time)

  if events.any?
    day_start = events.first.start_time.beginning_of_day
    day_end   = day_start + 24.hours

    segments = []
    current  = day_start

    events.each do |event|
      ev_start = event.start_time
      ev_end   = event.end_time

      if ev_start > current
        gap = (ev_start - current) / 60.0
        segments << { tooltip: nil, duration: gap, color: "#e0e0e0", free: true } if gap > 0
      end

      dur = (ev_end - ev_start) / 60.0
      if dur > 0
        tooltip_str = "#{ev_start.strftime('%H:%M')}〜#{ev_end.strftime('%H:%M')} #{event.title}"
        segments << { tooltip: tooltip_str, duration: dur, color: event.category.color_code, free: false }
      end

      current = ev_end if ev_end > current
    end

    if current < day_end
      remaining = (day_end - current) / 60.0
      segments << { tooltip: nil, duration: remaining, color: "#e0e0e0", free: true } if remaining > 0
    end

    raw_overlaps = []
    events.combination(2).each do |a, b|
      ov_start = [a.start_time, b.start_time].max
      ov_end   = [a.end_time,   b.end_time  ].min
      if ov_start < ov_end
        raw_overlaps << [(ov_start - day_start) / 60.0, (ov_end - day_start) / 60.0]
      end
    end

    raw_overlaps.sort!
    overlaps = []
    raw_overlaps.each do |s, e|
      if overlaps.empty? || overlaps.last[1] < s
        overlaps << [s, e]
      else
        overlaps.last[1] = [overlaps.last[1], e].max
      end
    end
  else
    segments = [{ tooltip: nil, duration: 1440.0, color: "#e0e0e0", free: true }]
    overlaps  = []
  end

  tooltip_labels = segments.map { |s| s[:tooltip] }
  values         = segments.map { |s| s[:duration] }
  colors         = segments.map { |s| s[:color] }
  is_free        = segments.map { |s| s[:free] }
%>

<div class="chart-wrapper">
  <canvas id="<%= chart_uid %>" width="260" height="260" style="max-width:260px;max-height:260px;"></canvas>
</div>

<script>
  (function() {
    var canvas = document.getElementById("<%= chart_uid %>");
    if (!canvas) return;
    var c = canvas.getContext("2d");

    var cx      = canvas.width  / 2;
    var cy      = canvas.height / 2;
    var outerR  = 90;
    var innerR  = 46;

    var durations      = <%= raw values.to_json %>;
    var colors         = <%= raw colors.to_json %>;
    var isFree         = <%= raw is_free.to_json %>;
    var tooltipLabels  = <%= raw tooltip_labels.to_json %>;
    var overlaps       = <%= raw overlaps.to_json %>;

    // 分 → 角度（0分=真上=midnight、時計回り）
    function ta(min) {
      return -Math.PI / 2 + (min / 1440) * 2 * Math.PI;
    }

    // ドーナツ弧を描く
    function drawArc(sa, ea, fillColor) {
      c.beginPath();
      c.arc(cx, cy, outerR, sa, ea);
      c.arc(cx, cy, innerR, ea, sa, true);
      c.closePath();
      c.fillStyle = fillColor;
      c.fill();
    }

    // セグメント描画
    var cum = 0;
    durations.forEach(function(dur, i) {
      drawArc(ta(cum), ta(cum + dur), colors[i]);
      cum += dur;
    });

    // かぶり区間を赤でオーバーレイ
    overlaps.forEach(function(ov) {
      drawArc(ta(ov[0]), ta(ov[1]), "rgba(220, 50, 50, 0.5)");
    });

    // セグメント間の白い区切り線
    cum = 0;
    durations.forEach(function(dur, i) {
      if (i > 0) {
        var angle = ta(cum);
        c.beginPath();
        c.moveTo(cx + innerR * Math.cos(angle), cy + innerR * Math.sin(angle));
        c.lineTo(cx + outerR * Math.cos(angle), cy + outerR * Math.sin(angle));
        c.strokeStyle = "#fff";
        c.lineWidth   = 2;
        c.stroke();
      }
      cum += dur;
    });

    // 0・6・12・18 の時刻マーカー
    [0, 6, 12, 18].forEach(function(hour) {
      var angle  = ta(hour * 60);
      var tick1  = outerR + 4;
      var tick2  = outerR + 11;
      var labelR = outerR + 22;

      c.beginPath();
      c.moveTo(cx + tick1 * Math.cos(angle), cy + tick1 * Math.sin(angle));
      c.lineTo(cx + tick2 * Math.cos(angle), cy + tick2 * Math.sin(angle));
      c.strokeStyle = "#999";
      c.lineWidth   = 1.5;
      c.stroke();

      c.font         = "bold 11px sans-serif";
      c.fillStyle    = "#555";
      c.textAlign    = "center";
      c.textBaseline = "middle";
      c.fillText(hour.toString(), cx + labelR * Math.cos(angle), cy + labelR * Math.sin(angle));
    });

    // ホバーツールチップ
    var tip = document.createElement("div");
    tip.style.cssText = "position:fixed;background:rgba(0,0,0,0.75);color:#fff;padding:4px 10px;border-radius:5px;font-size:12px;pointer-events:none;display:none;white-space:nowrap;z-index:9999;";
    document.body.appendChild(tip);

    canvas.addEventListener("mousemove", function(e) {
      var rect = canvas.getBoundingClientRect();
      var dx = e.clientX - rect.left - cx;
      var dy = e.clientY - rect.top  - cy;
      var dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < innerR || dist > outerR) {
        tip.style.display = "none";
        return;
      }

      var angle = Math.atan2(dy, dx) + Math.PI / 2;
      if (angle < 0) angle += 2 * Math.PI;
      var minutes = (angle / (2 * Math.PI)) * 1440;

      var cum2 = 0, found = -1;
      for (var i = 0; i < durations.length; i++) {
        cum2 += durations[i];
        if (minutes < cum2) { found = i; break; }
      }

      if (found === -1 || isFree[found]) {
        tip.style.display = "none";
        return;
      }

      tip.textContent    = tooltipLabels[found];
      tip.style.display  = "block";
      tip.style.left     = (e.clientX + 14) + "px";
      tip.style.top      = (e.clientY - 24) + "px";
    });

    canvas.addEventListener("mouseleave", function() {
      tip.style.display = "none";
    });
  })();
</script>
