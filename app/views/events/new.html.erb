<div class="event-new-wrapper">

<div class="event-new-container">

  <!-- 左上：戻るボタン -->
  <%= link_to "＜", @chart_date ? day_events_path(date: @chart_date) : events_path, class: "top-left" %>

  <!-- 日付・円グラフ（日付指定ありの場合のみ表示） -->
  <% if @chart_date %>
    <div class="event-date-header"><%= @chart_date.strftime("%Y年%m月%d日") %></div>
    <%= render "shared/chart", chart_events: @chart_events %>
  <% end %>

  <!-- エラーメッセージ -->
  <% if @event.errors.any? %>
    <div class="event-errors">
      <% @event.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @event do |f| %>
    <div class="event-btn-row">
      <!-- 予定追加ボタン：送信 -->
      <%= f.submit "予定を追加", class: "add-event-btn" %>
    </div>

    <div class="event-form-box">
      <div class="event-row">
        <span>タスク：</span>
        <%= f.text_field :title %>
      </div>

      <div class="event-row">
        <span>開始時間：</span>
        <%= f.datetime_local_field :start_time %>
      </div>

      <div class="event-row">
        <span>終了時間：</span>
        <%= f.datetime_local_field :end_time %>
      </div>

      <div class="event-row">
        <span>カテゴリー：</span>
        <%= f.select :category_id, @categories.map { |c| [c.category_name, c.id] }, { include_blank: "選択してください" } %>
        <details class="category-create">
          <summary>＋ 作成</summary>
          <input type="text"  name="new_category_name"  placeholder="カテゴリー名">
          <input type="color" name="new_category_color" value="#4aa8d8">
        </details>
      </div>

      <div class="event-memo">
        <span>メモ：</span>
        <%= f.text_area :memo %>
      </div>
    </div>
  <% end %>

</div>

<script>
  (function() {
    var categoryColors = <%= raw @categories.map { |c| [c.id.to_s, c.color_code] }.to_h.to_json %>;

    function getCanvas() {
      return document.querySelector(".chart-wrapper canvas");
    }

    function toMinutes(datetimeLocalValue) {
      if (!datetimeLocalValue) return null;
      var t = datetimeLocalValue.split("T")[1];
      if (!t) return null;
      var parts = t.split(":");
      return parseInt(parts[0], 10) * 60 + parseInt(parts[1], 10);
    }

    function updatePreview() {
      var canvas = getCanvas();
      if (!canvas || !canvas.drawPreview) return;

      var startInput     = document.getElementById("event_start_time");
      var endInput       = document.getElementById("event_end_time");
      var categorySelect = document.getElementById("event_category_id");
      var newColorInput  = document.querySelector("input[name='new_category_color']");

      var startMin = toMinutes(startInput && startInput.value);
      var endMin   = toMinutes(endInput   && endInput.value);

      var color = "#4aa8d8";
      if (categorySelect && categorySelect.value && categoryColors[categorySelect.value]) {
        color = categoryColors[categorySelect.value];
      } else if (newColorInput && newColorInput.value) {
        color = newColorInput.value;
      }

      canvas.drawPreview(startMin, endMin, color);
    }

    ["event_start_time", "event_end_time", "event_category_id"].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener("change", updatePreview);
    });

    var newColorInput = document.querySelector("input[name='new_category_color']");
    if (newColorInput) newColorInput.addEventListener("input", updatePreview);
  })();
</script>
